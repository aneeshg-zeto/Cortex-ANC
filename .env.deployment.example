# =============================================================================
# Railway deployment — copy to .env.deployment and fill in secrets from .env
# DO NOT COMMIT .env.deployment (gitignored)
# =============================================================================
#
# 1. cp .env.deployment.example .env.deployment
# 2. Paste secrets from .env (GROQ, Google, GitHub, etc.)
# 3. Replace YOUR_RAILWAY_URL with your Cortex-ANC public URL
# 4. In Railway dashboard: Cortex-ANC → Variables → paste or use CLI:
#      railway link && railway variables set --file .env.deployment
#
# DATABASE_URL: use Railway reference (do NOT paste localhost URL):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Required ---
DATABASE_URL=${{Postgres.DATABASE_URL}}

BETTER_AUTH_SECRET=
ENCRYPTION_KEY=
# Optional: Better Auth Infrastructure dashboard (requires @better-auth/infra dash plugin)
BETTER_AUTH_API_KEY=

GROQ_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BETTER_AUTH_URL=https://YOUR_RAILWAY_URL
NEXT_PUBLIC_APP_URL=https://YOUR_RAILWAY_URL

RAILWAY_ENV=true
NEXT_PUBLIC_SLIM_DEPLOY=true

LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile

# --- Sign-in OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Connector OAuth — replace YOUR_RAILWAY_URL in all redirect URIs ---
GITHUB_CONNECT_CLIENT_ID=
GITHUB_CONNECT_CLIENT_SECRET=
GITHUB_CONNECT_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/github
GOOGLE_CONNECT_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/google

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/notion

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/slack

JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/jira

CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/confluence

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/zoom

CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/oauth/callback/calendly

# --- Optional ---
USE_LLM_ENTITY_EXTRACTION=true
# Set false to skip per-page LLM entity extraction during Notion ingest (much faster).
LOG_LEVEL=info

# --- Temporary prod shortcut (remove after rollout) ---
EMPLOYEE_DEV_BYPASS=true
EMPLOYEE_DEV_PASSWORD=cortex-employee-dev

# --- DO NOT SET on Railway V1 (local-only / workers) ---
# LITELLM_URL
# KAFKA_BROKERS
# TEMPORAL_ADDRESS
# NEO4J_URI
# REDIS_URL
# ELASTICSEARCH_URL
# INTEGRATION_SERVICE_*
# HR_DEV_BYPASS
# EMPLOYEE_DEV_BYPASS
