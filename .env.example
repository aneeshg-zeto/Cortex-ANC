# LLM Provider: groq or ollama
LLM_PROVIDER=groq
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_LLM_MODEL=llama3:8b

# Embeddings (Ollama)
EMBEDDING_MODEL=nomic-embed-text

# PostgreSQL + pgvector (optional — falls back to in-memory store)
DATABASE_URL=postgresql://cortex:cortex@localhost:5434/cortex

# Connector credentials (Phase 1 – wire via secure store later)
SLACK_BOT_TOKEN=
SLACK_INGEST_CHANNEL=
GITHUB_TOKEN=
LINEAR_API_KEY=
NOTION_TOKEN=
GMAIL_OAUTH_TOKEN=
