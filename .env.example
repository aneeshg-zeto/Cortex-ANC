# =============================================================================
# Cortex Platform — environment variables
# =============================================================================

# --- LLM (Groq via LiteLLM) ---
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
LITELLM_MODEL=cortex-groq
LITELLM_FALLBACK_MODEL=cortex-gemini
LITELLM_EMBED_MODEL=cortex-embed
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=cortex-local-dev

# --- Database & auth ---
DATABASE_URL=postgresql://cortex:cortex@localhost:5434/cortex
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENCRYPTION_KEY=

# Railway V1 slim deploy — web + Postgres only (2 resources).
# Do NOT add Kafka, Temporal, Neo4j, Redis, or LiteLLM services.

# Required
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
GROQ_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENCRYPTION_KEY=
RAILWAY_ENV=true
NEXT_PUBLIC_SLIM_DEPLOY=true

# Leave unset on Railway (uses direct Groq, no background workers):
# LITELLM_URL, KAFKA_BROKERS, TEMPORAL_ADDRESS, NEO4J_URI, REDIS_URL
# HR_DEV_BYPASS, EMPLOYEE_DEV_BYPASS

# HR dev bypass removed — use company code Zeto + HR role, or CEO account + /hr
HR_DEV_BYPASS=false
HR_DEV_PASSWORD=cortex-hr-dev
# Optional: pin all company-code sign-ins to one tenant (else slug `zeto` is used)
# COMPANY_TENANT_ID=tenant-abc12345
# Employee bypass — login page shortcut (allowed in production when enabled)
EMPLOYEE_DEV_BYPASS=true
EMPLOYEE_DEV_PASSWORD=cortex-employee-dev

# --- Sign-in OAuth (Better Auth callbacks: /api/auth/callback/{provider}) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Connector OAuth (callbacks: /api/oauth/callback/{provider}) ---
# Active gallery connectors: Google Workspace, GitHub, Notion, Slack, Jira, Confluence,
# Microsoft 365, Zoom, Calendly, Linear (coming soon).

GITHUB_CONNECT_CLIENT_ID=
GITHUB_CONNECT_CLIENT_SECRET=
GITHUB_CONNECT_REDIRECT_URI=http://localhost:3000/api/oauth/callback/github
GOOGLE_CONNECT_REDIRECT_URI=http://localhost:3000/api/oauth/callback/google

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/oauth/callback/notion

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/oauth/callback/slack

JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/api/oauth/callback/jira

CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=http://localhost:3000/api/oauth/callback/confluence

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/oauth/callback/microsoft

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:3000/api/oauth/callback/zoom

CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=http://localhost:3000/api/oauth/callback/calendly

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:3000/api/oauth/callback/linear

# --- Infrastructure ---
INTEGRATION_SERVICE_PORT=3010
NEXT_PUBLIC_INTEGRATION_SERVICE_URL=http://localhost:3010
INTEGRATION_SERVICE_PUBLIC_URL=http://localhost:3010
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6380
ELASTICSEARCH_URL=http://localhost:9200
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexneo4j
NEO4J_HTTP_URL=http://localhost:7474
TEMPORAL_ADDRESS=localhost:7233

# --- Optional (not required on Railway V1) ---
USE_LLM_ENTITY_EXTRACTION=true
LOG_LEVEL=info
# LOKI_URL=http://localhost:3100

# =====================================================================
# CEO Intelligence Layer v2 — connectors & services
# Every key below is optional. When unset, the related connector returns
# empty data and its endpoints still respond 200 OK.
# =====================================================================

# --- F1/F2 Customers & Sales (CRM) ---
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=

# --- F1/F3 Billing & Payments ---
STRIPE_SECRET_KEY=

# --- F1/F4 Support / Helpdesk ---
INTERCOM_ACCESS_TOKEN=
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
FRONT_API_TOKEN=

# --- F3 Finance (banking & accounting) ---
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_API_BASE=https://quickbooks.api.intuit.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
PLAID_API_BASE=https://production.plaid.com
MERCURY_API_TOKEN=

# --- F7 Competitive & market signals ---
APIFY_TOKEN=
APIFY_TASK_ID=
PRODUCTHUNT_TOKEN=
COMPETITIVE_ALERT_PCT=10

# --- F11 Hiring (ATS) ---
GREENHOUSE_API_KEY=
LEVER_API_KEY=
ASHBY_API_KEY=

# --- F20 Morning digest (email + push) ---
RESEND_API_KEY=
DIGEST_FROM_EMAIL=Cortex <onboarding@resend.dev>
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@cortex.local
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Shared secret the daily 8am cron sends as the x-cron-secret header
CRON_SECRET=
