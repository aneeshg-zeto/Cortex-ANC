# LLM
LLM_PROVIDER=groq
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_LLM_MODEL=llama3:8b
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=cortex-local-dev

# Database
DATABASE_URL=postgresql://cortex:cortex@localhost:5434/cortex

# Kafka
KAFKA_BROKERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6380

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Neo4j (optional read replica)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexneo4j

# Temporal
TEMPORAL_ADDRESS=localhost:7233

# Nango
NANGO_SECRET_KEY=
NANGO_SERVER_URL=http://localhost:3003
INTEGRATION_SERVICE_PORT=3010
NEXT_PUBLIC_INTEGRATION_SERVICE_URL=http://localhost:3010

# Clerk (optional — desks work without auth locally)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Sentry (optional)
SENTRY_DSN=

# Observability
LOKI_URL=http://localhost:3100
LOG_LEVEL=info

# Connectors
SLACK_BOT_TOKEN=
SLACK_INGEST_CHANNEL=
GITHUB_TOKEN=
LINEAR_API_KEY=
NOTION_TOKEN=
GMAIL_OAUTH_TOKEN=

# Entity extraction (Ollama)
USE_LLM_ENTITY_EXTRACTION=false
