{
  "name": "cortex-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@cortex/web --filter=@cortex/shared --filter=@cortex/agent-core --filter=@cortex/ui --filter=@cortex/graph-core",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@cortex/web",
    "start:web": "bun run --cwd apps/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "smoke:slack": "bun run packages/integration-core/scripts/smoke-slack.ts",
    "db:wipe": "bash scripts/wipe-data.sh",
    "auth:migrate": "bash scripts/migrate-auth.sh",
    "test:brain": "bun run scripts/test-brain.ts",
    "test:ollama": "echo 'Ollama disabled — using Groq only'",
    "demo": "bash scripts/demo.sh",
    "start:all": "bash scripts/start-all.sh start",
    "start:all:stop": "bash scripts/start-all.sh stop",
    "db:up": "docker compose up -d postgres",
    "infra:up": "docker compose up -d",
    "db:init": "bash scripts/init-db.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "seed:zeto": "bun run scripts/seed-zeto-studio.ts",
    "clear:ingestions": "bash scripts/clear-ingestions.sh",
    "adapt:connectors": "bun run scripts/adapt-connectors.ts",
    "services:dev": "bun run --filter '@cortex/integration-service' dev & bun run --filter '@cortex/event-consumer' dev & bun run --filter '@cortex/temporal-worker' dev",
    "temporal:dev": "bun run --filter '@cortex/temporal-worker' dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.33",
    "caniuse-lite": "^1.0.30001793"
  }
}
