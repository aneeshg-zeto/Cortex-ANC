{
  "name": "@cortex/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kafka": {
      "types": "./dist/kafka/index.d.ts",
      "import": "./dist/kafka/index.js"
    },
    "./temporal/client": {
      "types": "./dist/temporal/client.d.ts",
      "import": "./dist/temporal/client.js"
    },
    "./temporal/types": {
      "types": "./dist/temporal/types.d.ts",
      "import": "./dist/temporal/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@temporalio/client": "^1.11.7",
    "kafkajs": "^2.2.4",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.8.2"
  }
}
